{
  "name": "e-insight",
  "version": "1.0.0",
  "private": true,
  "description": "e-Insight — Enterprise Decision Support System for SIMPATI.KK",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\" \"npm run dev:ml\"",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:backend": "npm run start:dev --prefix backend",
    "dev:ml": "cd ml-service && python -m uvicorn main:app --host 0.0.0.0 --port 8000",
    "dev:email-webhook": "node backend/scripts/email-webhook-receiver.mjs",
    "test:e2e": "node backend/scripts/e2e-smoke.mjs",
    "build": "npm run build --prefix frontend && npm run build --prefix backend",
    "build:frontend": "npm run build --prefix frontend",
    "deploy:pages": "npm run build:frontend && npx wrangler pages deploy frontend/dist --project-name=e-insight --branch=main --commit-dirty=true",
    "deploy:pages:init": "wrangler pages project create e-insight --production-branch main",
    "tunnel:api": "powershell -ExecutionPolicy Bypass -File scripts/start-api-tunnel.ps1",
    "tunnel:api:sync": "powershell -ExecutionPolicy Bypass -File scripts/start-api-tunnel.ps1 -UpdateSecret",
    "tunnel:ml": "powershell -ExecutionPolicy Bypass -File scripts/start-ml-tunnel.ps1",
    "tunnel:ml:sync": "powershell -ExecutionPolicy Bypass -File scripts/start-ml-tunnel.ps1 -UpdateSecret",
    "ml:sync-url": "powershell -ExecutionPolicy Bypass -File scripts/sync-ml-url.ps1",
    "llm:setup": "powershell -ExecutionPolicy Bypass -File scripts/setup-llm.ps1",
    "deploy:worker": "npm run deploy:worker --prefix backend",
    "export:powerbi": "node backend/scripts/export-powerbi-csv.js",
    "fix": "npm run build --prefix backend && npm run dev",
    "geocode": "npm run geocode --prefix backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.0",
    "xlsx": "^0.18.5"
  }
}
