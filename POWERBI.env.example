# Power BI — Cloudflare Pages secrets (Production)
# Quick setup: salin URL ke powerbi.env lalu npm run powerbi:setup

# Opsi B: Link Share report (paling mudah — copy URL address bar)
POWERBI_SHARE_URL=

# Opsi A: URL embed iframe (Publish to Web)
POWERBI_EMBED_URL=

# Opsi C: Service Principal (Azure AD App)
POWER_BI_TENANT_ID=
POWER_BI_CLIENT_ID=
POWER_BI_CLIENT_SECRET=
POWER_BI_WORKSPACE_ID=
POWER_BI_REPORT_ID=

# ML + LLM (referensi — lihat groq.env / openai.env)
# ML_SERVICE_URL=https://e-insight-e-insight-ml.hf.space
# OPENAI_API_KEY=gsk_... atau sk-...
# AI_MODEL=llama-3.3-70b-versatile
