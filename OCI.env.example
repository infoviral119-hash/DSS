# Oracle Cloud — VM Metabase e-Insight
# Salin ke oci.env (gitignored), isi setelah VM dibuat.

# Public IP VM Oracle (Compute -> Instances -> Public IP)
OCI_HOST=

# SSH user (Ubuntu image = ubuntu, Oracle Linux = opc)
OCI_SSH_USER=ubuntu

# Path ke private key SSH (.pem dari Oracle atau id_rsa)
OCI_SSH_KEY=

# Opsional — override URL Metabase (default: https://<ip-dashes>.sslip.io)
# METABASE_URL=
