# Metabase — BI dashboard (gratis, self-host)
# Salin ke metabase.env (gitignored) lalu: npm run metabase:setup
#
# Langkah singkat:
#   1. npm run metabase:start          → http://localhost:3000
#   2. Setup admin → Add database → PostgreSQL (Supabase)
#   3. Buat dashboard → Share → Public link
#   4. Paste URL public dashboard di bawah
#   5. npm run metabase:setup            → sync ke Cloudflare Pages
#
# Supabase Postgres (Settings → Database → Connection string URI):
#   Host     : db.<project-ref>.supabase.co
#   Port     : 5432
#   Database : postgres
#   User     : postgres
#   SSL      : require
#   Tabel utama: cases, profiles, import_batches
#
# Untuk akses dari internet (PC nyala): npm run metabase:tunnel:sync
# Gabungkan tunnel URL + path public dashboard, contoh:
#   https://xxxx.trycloudflare.com/public/dashboard/abc-123

METABASE_DASHBOARD_URL=

# Opsional — link ke Metabase admin (bukan embed iframe)
METABASE_PUBLIC_URL=
